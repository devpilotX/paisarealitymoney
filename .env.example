# PostgreSQL — single database for the entire app
# Either set DATABASE_URL, or the discrete PG* vars below.
DATABASE_URL=
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGDATABASE=paisareality

# JWT / Auth
JWT_SECRET=local-dummy-jwt-change-in-prod

# Razorpay
RAZORPAY_KEY_ID=rzp_test_dummy
RAZORPAY_KEY_SECRET=dummy
RAZORPAY_WEBHOOK_SECRET=dummy

# Resend (email)
RESEND_API_KEY=re_dummy

# Public
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_ADSENSE_PUB_ID=6484525483464374
NEXT_PUBLIC_ADSENSE_DEFAULT_SLOT=
NEXT_PUBLIC_ADSENSE_IN_ARTICLE_SLOT=

# Cron
CRON_SECRET=dummy-cron-secret

# Yojana Mitra assistant (optional). Without a key the guided responder is used.
GEMINI_API_KEY=
# Optional: pin a model; falls back through gemini-2.5-flash -> gemini-2.0-flash.
GEMINI_MODEL=

# Metal price calibration (optional; sensible defaults in code).
# India's gold/silver customs duty is 15% (10% BCD + 5% AIDC) since 13 May 2026.
# We keep the duty knob near 6% and let MARKET_PREMIUM absorb the observed gap
# to published Indian dealer rates (Indian retail gold does not pass the full
# statutory duty through). Duty and premium are entangled: re-fit the premium
# to current dealer rates rather than bumping duty alone.
# Production values (calibrated vs GoodReturns/LiveMint/HDFC):
#   GOLD_MARKET_PREMIUM=0.04    (calibrated 2026-07-21)
#   SILVER_MARKET_PREMIUM=0.175 (calibrated 2026-07-03)
GOLD_IMPORT_DUTY=
GOLD_MARKET_PREMIUM=0.04
SILVER_IMPORT_DUTY=
SILVER_MARKET_PREMIUM=0.175
