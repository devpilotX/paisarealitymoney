{
  "name": "paisareality",
  "version": "2.0.0",
  "private": true,
  "description": "India's one-stop money hub.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -H 0.0.0.0 -p ${PORT:-3306}",
    "lint": "tsc --noEmit --pretty false",
    "db:seed-cities": "ts-node -r dotenv/config --project tsconfig.scripts.json scripts/seed-cities.ts",
    "db:seed-prices": "ts-node -r dotenv/config --project tsconfig.scripts.json scripts/seed-prices.ts",
    "db:seed-schemes": "ts-node -r dotenv/config --project tsconfig.scripts.json scripts/seed-schemes.ts",
    "db:seed-banks": "ts-node -r dotenv/config --project tsconfig.scripts.json scripts/seed-banks.ts",
    "db:seed-all": "npm run db:seed-cities && npm run db:seed-prices && npm run db:seed-schemes && npm run db:seed-banks"
  },
  "dependencies": {
    "@react-pdf/renderer": "^3.4.4",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/sanitize-html": "^2.11.0",
    "autoprefixer": "^10.4.27",
    "bcrypt": "^6.0.0",
    "dotenv": "^16.4.5",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.3",
    "jsonwebtoken": "^9.0.2",
    "lru-cache": "^10.2.2",
    "marked": "^12.0.2",
    "mysql2": "^3.9.7",
    "next": "^16.2.3",
    "postcss": "^8.5.9",
    "razorpay": "^2.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^3.2.0",
    "sanitize-html": "^2.13.0",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  }
}